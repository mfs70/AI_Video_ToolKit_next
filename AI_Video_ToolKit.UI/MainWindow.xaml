<Window x:Class="AI_Video_ToolKit.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Video Toolkit"
        Height="720" Width="1200"
        Background="#202020">

    <Grid>

        <!-- ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- COLUMNS -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Background="#2D2D30">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputPathBox" Margin="10"/>
            <Button Grid.Column="1" Content="Browse" Click="BrowseInput_Click"/>

            <TextBox Grid.Column="2" x:Name="OutputPathBox" Margin="10"/>
            <Button Grid.Column="3" Content="Browse" Click="BrowseOutput_Click"/>

        </Grid>

        <!-- LEFT -->
        <StackPanel Grid.Row="1" Grid.Column="0" Background="#252526">

            <Button Content="Probe" Height="50" Margin="10" Click="Probe_Click"/>
            <Button Content="Preview" Height="50" Margin="10" Click="Preview_Click"/>
            <Button Content="Encode" Height="50" Margin="10" Click="Encode_Click"/>

        </StackPanel>

        <!-- MAIN -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="5">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <!-- VIDEO -->
            <Grid Background="Black">

                <MediaElement x:Name="VideoPlayer"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Manual"
                              Stretch="Uniform"
                              MediaOpened="VideoPlayer_MediaOpened"/>

                <Border Background="#66000000"
                        VerticalAlignment="Bottom"
                        Margin="10"
                        Padding="5">

                    <StackPanel>

                        <!-- TIMELINE -->
                        <Slider x:Name="TimelineSlider"
                                Minimum="0"
                                Maximum="1"
                                ValueChanged="TimelineSlider_ValueChanged"/>

                        <!-- TIME -->
                        <TextBlock x:Name="TimeText"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>

                        <!-- CONTROLS -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">

                            <Button Content="▶" Width="50" Click="Play_Click"/>
                            <Button Content="⏸" Width="50" Click="Pause_Click"/>
                            <Button Content="⏹" Width="50" Click="Stop_Click"/>

                        </StackPanel>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- LOG -->
            <TextBox x:Name="LogBox"
                     Grid.Row="1"
                     Background="#000"
                     Foreground="#00FF00"
                     FontFamily="Consolas"
                     IsReadOnly="True"/>

        </Grid>

        <!-- STATUS -->
        <Grid Grid.Row="2" Grid.ColumnSpan="2" Background="#2D2D30">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusText"
                       Text="Ready"
                       Margin="10"
                       VerticalAlignment="Center"
                       Foreground="White"/>

            <ProgressBar x:Name="ProgressBar"
                         Grid.Column="1"
                         Margin="10"
                         Height="20"/>

        </Grid>

    </Grid>
</Window>