<Window x:Class="AI_Video_ToolKit.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AI_Video_ToolKit.UI.Controls"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        xmlns:sw="clr-namespace:System.Windows;assembly=PresentationFramework"
        xmlns:converters="clr-namespace:AI_Video_ToolKit.UI.Converters"
        Title="AI Video Toolkit – Professional Video Editor"
        Width="1400"
                Height="850"
        MinWidth="1000"
                MinHeight="600"
        Background="#1E1E1E"
        PreviewKeyDown="Window_PreviewKeyDown"
        AllowDrop="True"
                Drop="Window_Drop"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal">

        <Window.Resources>
                <converters:ProgressBarWidthConverter x:Key="ProgressBarWidthConverter"/>

                <SolidColorBrush x:Key="BackgroundDarkBrush"
                                Color="#1E1E1E"/>
                <SolidColorBrush x:Key="SurfaceBrush"
                                Color="#121212"/>
                <SolidColorBrush x:Key="SurfaceLightBrush"
                                Color="#1A1A1A"/>
                <SolidColorBrush x:Key="SurfaceMediumBrush"
                                Color="#2C2C2C"/>
                <SolidColorBrush x:Key="BorderBrush"
                                Color="#3A3A3A"/>
                <SolidColorBrush x:Key="BorderLightBrush"
                                Color="#555555"/>
                <SolidColorBrush x:Key="AccentBrush"
                                Color="#3A6EA5"/>
                <SolidColorBrush x:Key="AccentHoverBrush"
                                Color="#4C9AFF"/>
                <SolidColorBrush x:Key="TextPrimaryBrush"
                                Color="#E0E0E0"/>
                <SolidColorBrush x:Key="TextSecondaryBrush"
                                Color="#888888"/>
                <SolidColorBrush x:Key="TextAccentBrush"
                                Color="#FFAA66"/>
                <SolidColorBrush x:Key="TextSpecialBrush"
                                Color="#4C9AFF"/>
                <SolidColorBrush x:Key="LogTextBrush"
                                Color="#A5E1A5"/>

                <FontFamily x:Key="MonospaceFont">Consolas</FontFamily>
                <sw:CornerRadius x:Key="ControlCornerRadius">4</sw:CornerRadius>
                <sw:CornerRadius x:Key="CardCornerRadius">6</sw:CornerRadius>
                <sw:CornerRadius x:Key="CircleRadius">21</sw:CornerRadius>

                <Style TargetType="ToolTip">
                        <Setter Property="Background"
                                        Value="{StaticResource SurfaceMediumBrush}"/>
                        <Setter Property="Foreground"
                                        Value="{StaticResource TextPrimaryBrush}"/>
                        <Setter Property="BorderBrush"
                                        Value="{StaticResource BorderLightBrush}"/>
                        <Setter Property="BorderThickness"
                                        Value="1"/>
                        <Setter Property="Padding"
                                        Value="8,4"/>
                        <Setter Property="FontSize"
                                        Value="11"/>
                </Style>

                <Style x:Key="PrimaryButton"
                                TargetType="Button">
                        <Setter Property="Background"
                                        Value="{StaticResource AccentBrush}"/>
                        <Setter Property="Foreground"
                                        Value="White"/>
                        <Setter Property="BorderThickness"
                                        Value="0"/>
                        <Setter Property="Padding"
                                        Value="12,8"/>
                        <Setter Property="FontSize"
                                        Value="12"/>
                        <Setter Property="Cursor"
                                        Value="Hand"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="{StaticResource ControlCornerRadius}"
                                                        Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                        Value="True">
                                                                <Setter Property="Background"
                                                                                Value="#2C5A8C"/>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <Style x:Key="SecondaryButton"
                                TargetType="Button">
                        <Setter Property="Background"
                                        Value="{StaticResource SurfaceMediumBrush}"/>
                        <Setter Property="Foreground"
                                        Value="{StaticResource TextPrimaryBrush}"/>
                        <Setter Property="BorderThickness"
                                        Value="1"/>
                        <Setter Property="BorderBrush"
                                        Value="{StaticResource BorderLightBrush}"/>
                        <Setter Property="Padding"
                                        Value="10,6"/>
                        <Setter Property="FontSize"
                                        Value="11"/>
                        <Setter Property="Cursor"
                                        Value="Hand"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="{StaticResource ControlCornerRadius}"
                                                        Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                        Value="True">
                                                                <Setter Property="Background"
                                                                                Value="#3C3C3C"/>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <Style x:Key="TransportButton"
                                TargetType="Button">
                        <Setter Property="Width"
                                        Value="42"/>
                        <Setter Property="Height"
                                        Value="42"/>
                        <Setter Property="Background"
                                        Value="{StaticResource SurfaceMediumBrush}"/>
                        <Setter Property="Foreground"
                                        Value="White"/>
                        <Setter Property="FontSize"
                                        Value="18"/>
                        <Setter Property="Cursor"
                                        Value="Hand"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="{StaticResource CircleRadius}"
                                                                Padding="0">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                        Value="True">
                                                                <Setter Property="Background"
                                                                                Value="{StaticResource AccentBrush}"/>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <Style x:Key="LoadButtonStyle"
                                TargetType="Button">
                        <Setter Property="Width"
                                        Value="42"/>
                        <Setter Property="Height"
                                        Value="42"/>
                        <Setter Property="Background"
                                        Value="{StaticResource SurfaceMediumBrush}"/>
                        <Setter Property="Foreground"
                                        Value="White"/>
                        <Setter Property="FontSize"
                                        Value="20"/>
                        <Setter Property="Cursor"
                                        Value="Hand"/>
                        <Setter Property="ToolTip"
                                        Value="Open files (Ctrl+L)"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="{StaticResource CircleRadius}"
                                                                Padding="0">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                        Value="True">
                                                                <Setter Property="Background"
                                                                                Value="{StaticResource AccentHoverBrush}"/>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <Style x:Key="CompactSpeedComboBox"
                                TargetType="ComboBox">
                        <Setter Property="Width"
                                        Value="65"/>
                        <Setter Property="Height"
                                        Value="30"/>
                        <Setter Property="Background"
                                        Value="#1A1A1A"/>
                        <Setter Property="Foreground"
                                        Value="White"/>
                        <Setter Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}"/>
                        <Setter Property="BorderThickness"
                                        Value="1"/>
                        <Setter Property="FontSize"
                                        Value="12"/>
                        <Setter Property="FontWeight"
                                        Value="Bold"/>
                        <Setter Property="HorizontalContentAlignment"
                                        Value="Center"/>
                        <Setter Property="VerticalContentAlignment"
                                        Value="Center"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="ComboBox">
                                                <Grid>
                                                        <ToggleButton x:Name="ToggleButton"
                                                                      Background="{TemplateBinding Background}"
                                                                      BorderBrush="{TemplateBinding BorderBrush}"
                                                                      BorderThickness="{TemplateBinding BorderThickness}"
                                                                      Foreground="{TemplateBinding Foreground}"
                                                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                                      Padding="6,4">
                                                                <ToggleButton.Template>
                                                                        <ControlTemplate TargetType="ToggleButton">
                                                                                <Border Background="{TemplateBinding Background}"
                                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                                        CornerRadius="{StaticResource ControlCornerRadius}"
                                                                                        Padding="{TemplateBinding Padding}">
                                                                                        <Grid>
                                                                                                <Grid.ColumnDefinitions>
                                                                                                        <ColumnDefinition Width="*"/>
                                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                                </Grid.ColumnDefinitions>
                                                                                                <ContentPresenter Grid.Column="0"
                                                                                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                                                                  Content="{Binding SelectedItem, RelativeSource={RelativeSource TemplatedParent}}"
                                                                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource TemplatedParent}}"/>
                                                                                                <Path Grid.Column="1"
                                                                                                                Data="M 0 0 L 4 4 L 8 0 Z"
                                                                                                      Fill="{TemplateBinding Foreground}"
                                                                                                                Margin="5,0,0,0"
                                                                                                                VerticalAlignment="Center"/>
                                                                                        </Grid>
                                                                                </Border>
                                                                        </ControlTemplate>
                                                                </ToggleButton.Template>
                                                        </ToggleButton>
                                                        <Popup x:Name="Popup"
                                                                        AllowsTransparency="True"
                                                               IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                                               Placement="Bottom"
                                                                        PopupAnimation="Slide">
                                                                <Border Background="{StaticResource SurfaceMediumBrush}"
                                                                        BorderBrush="{StaticResource AccentBrush}"
                                                                                BorderThickness="1"
                                                                        CornerRadius="{StaticResource ControlCornerRadius}"
                                                                        MinWidth="{TemplateBinding ActualWidth}">
                                                                        <ScrollViewer>
                                                                                <ItemsPresenter/>
                                                                        </ScrollViewer>
                                                                </Border>
                                                        </Popup>
                                                </Grid>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <Style TargetType="ComboBoxItem">
                        <Setter Property="Background"
                                        Value="{StaticResource SurfaceMediumBrush}"/>
                        <Setter Property="Foreground"
                                        Value="White"/>
                        <Setter Property="Height"
                                        Value="28"/>
                        <Setter Property="Padding"
                                        Value="8,4"/>
                        <Style.Triggers>
                                <Trigger Property="IsHighlighted"
                                                Value="True">
                                        <Setter Property="Background"
                                                        Value="{StaticResource AccentBrush}"/>
                                        <Setter Property="Foreground"
                                                        Value="White"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <Style TargetType="ListBox">
                        <Setter Property="Background"
                                        Value="#0C0C0C"/>
                        <Setter Property="BorderBrush"
                                        Value="{StaticResource BorderBrush}"/>
                        <Setter Property="BorderThickness"
                                        Value="1"/>
                        <Setter Property="FontFamily"
                                        Value="{StaticResource MonospaceFont}"/>
                        <Setter Property="FontSize"
                                        Value="11"/>
                </Style>

                <Style TargetType="ListBoxItem">
                        <Setter Property="Padding"
                                        Value="8,6"/>
                        <Setter Property="Foreground"
                                        Value="{StaticResource TextPrimaryBrush}"/>
                        <Setter Property="Background"
                                        Value="Transparent"/>
                        <Style.Triggers>
                                <Trigger Property="IsSelected"
                                                Value="True">
                                        <Setter Property="Background"
                                                        Value="{StaticResource AccentBrush}"/>
                                        <Setter Property="Foreground"
                                                        Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver"
                                                Value="True">
                                        <Setter Property="Background"
                                                        Value="#2A2A2A"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <Style TargetType="GroupBox">
                        <Setter Property="BorderBrush"
                                        Value="#444444"/>
                        <Setter Property="BorderThickness"
                                        Value="1"/>
                        <Setter Property="Background"
                                        Value="{StaticResource SurfaceBrush}"/>
                        <Setter Property="Foreground"
                                        Value="#DDDDDD"/>
                        <Setter Property="FontSize"
                                        Value="12"/>
                        <Setter Property="Margin"
                                        Value="0,0,0,8"/>
                        <Setter Property="Padding"
                                        Value="6"/>
                </Style>

                <Style x:Key="CustomProgressBar"
                                TargetType="ProgressBar">
                        <Setter Property="Background"
                                        Value="#2B2B2B"/>
                        <Setter Property="Foreground"
                                        Value="{StaticResource AccentHoverBrush}"/>
                        <Setter Property="Height"
                                        Value="20"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="ProgressBar">
                                                <Grid>
                                                        <Border CornerRadius="4"
                                                                        Background="{TemplateBinding Background}"/>
                                                        <Border CornerRadius="4"
                                                                        Background="{TemplateBinding Foreground}"
                                                                HorizontalAlignment="Left">
                                                                <Border.Width>
                                                                        <MultiBinding Converter="{StaticResource ProgressBarWidthConverter}">
                                                                                <Binding Path="Value"
                                                                                                RelativeSource="{RelativeSource TemplatedParent}"/>
                                                                                <Binding Path="Maximum"
                                                                                                RelativeSource="{RelativeSource TemplatedParent}"/>
                                                                                <Binding Path="ActualWidth"
                                                                                                RelativeSource="{RelativeSource TemplatedParent}"/>
                                                                        </MultiBinding>
                                                                </Border.Width>
                                                        </Border>
                                                        <TextBlock Foreground="White"
                                                                        FontSize="10"
                                                                        FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                   Text="{Binding Path=Value, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0:0}%}"/>
                                                </Grid>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>
        </Window.Resources>

        <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ROW 0: ОСНОВНАЯ ОБЛАСТЬ -->
                <Grid Grid.Row="0"
                                Margin="10">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ПЛЕЙЛИСТ -->
                        <Border Grid.Column="0"
                                        Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                CornerRadius="{StaticResource CardCornerRadius}">
                                <Grid>
                                        <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0"
                                                        Background="{StaticResource SurfaceLightBrush}"
                                                CornerRadius="6,6,0,0"
                                                        Padding="8,6">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📋 Playlist"
                                                                        Foreground="{StaticResource TextSpecialBrush}"
                                                                   FontSize="12"
                                                                        FontWeight="Bold"/>
                                                        <Border Background="{StaticResource AccentBrush}"
                                                                        CornerRadius="10"
                                                                        Padding="4,1"
                                                                        Margin="10,0,0,0">
                                                                <TextBlock Text="{Binding PlaylistItems.Count, StringFormat={}{0} items}"
                                                                                Foreground="White"
                                                                                FontSize="9"/>
                                                        </Border>
                                                </StackPanel>
                                        </Border>
                                        <ListBox x:Name="PlaylistListBox"
                                                        Grid.Row="1"
                                                        Background="#0C0C0C"
                                                        BorderThickness="0"
                                                 ItemsSource="{Binding PlaylistItems}"
                                                 SelectedItem="{Binding SelectedPlaylistItem}"
                                                 AllowDrop="True"
                                                        Drop="Playlist_Drop"
                                                        DragOver="Playlist_DragOver"
                                                 VirtualizingStackPanel.IsVirtualizing="True"
                                                 VirtualizingStackPanel.VirtualizationMode="Recycling">
                                                <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                                <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding TypeIcon}"
                                                                                        Margin="0,0,5,0"/>
                                                                        <TextBlock Text="{Binding FileName}"/>
                                                                </StackPanel>
                                                        </DataTemplate>
                                                </ListBox.ItemTemplate>
                                        </ListBox>
                                        <StackPanel Grid.Row="2"
                                                        Orientation="Horizontal"
                                                        Margin="6"
                                                        HorizontalAlignment="Center">
                                                <Button Command="{Binding ClearPlaylistCommand}"
                                                                Content="Clear"
                                                                Width="60"
                                                                Height="25"
                                                        Margin="0,0,6,0"
                                                                Style="{StaticResource SecondaryButton}"/>
                                                <Button Command="{Binding RemoveSelectedFromPlaylistCommand}"
                                                                Content="Remove Sel"
                                                                Width="80"
                                                                Height="25"
                                                        Style="{StaticResource SecondaryButton}"/>
                                        </StackPanel>
                                </Grid>
                        </Border>

                        <GridSplitter Grid.Column="1"
                                        Width="4"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Stretch"
                                      Background="{StaticResource BorderBrush}"/>

                        <!-- ВИДЕО ПЛЕЕР -->
                        <Border Grid.Column="2"
                                        Background="#000000"
                                        BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                        CornerRadius="8"
                                        AllowDrop="True"
                                        Drop="Player_Drop"
                                        DragOver="Player_DragOver">
                                <controls:VideoPreviewControl x:Name="Preview"/>
                        </Border>

                        <GridSplitter Grid.Column="3"
                                        Width="4"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Stretch"
                                      Background="{StaticResource BorderBrush}"/>

                        <!-- ПРАВАЯ ПАНЕЛЬ -->
                        <StackPanel Grid.Column="4"
                                        Orientation="Vertical">
                                <GroupBox Header="📋 Logger"
                                                Height="200">
                                        <ListBox x:Name="LogList"
                                                        Background="#0C0C0C"
                                                 Foreground="{StaticResource LogTextBrush}"
                                                        FontSize="10"
                                                 VirtualizingStackPanel.IsVirtualizing="True"
                                                 VirtualizingStackPanel.VirtualizationMode="Recycling"/>
                                </GroupBox>
                                <GroupBox Header="✂️ Segments"
                                                Height="200">
                                        <ListBox x:Name="SegmentList"
                                                        Background="#0C0C0C"
                                                 ItemsSource="{Binding Segments}"
                                                 SelectedItem="{Binding SelectedSegment}"
                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                 VirtualizingStackPanel.IsVirtualizing="True"
                                                 VirtualizingStackPanel.VirtualizationMode="Recycling">
                                                <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                                <TextBlock Text="{Binding}"/>
                                                        </DataTemplate>
                                                </ListBox.ItemTemplate>
                                        </ListBox>
                                </GroupBox>
                        </StackPanel>
                </Grid>

                <!-- ROW 1: МЕТАДАННЫЕ -->
                <Grid Grid.Row="1"
                                Background="#252526">
                        <WrapPanel Margin="10,6"
                                        HorizontalAlignment="Left">
                                <TextBlock Text="{Binding CurrentFileName}"
                                                Foreground="{StaticResource TextAccentBrush}"
                                                FontSize="12"
                                                FontWeight="Bold"
                                                Margin="0,0,20,0"/>
                                <TextBlock Text="{Binding Resolution, StringFormat='Resolution: {0}'}"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                FontSize="11"
                                                Margin="0,0,15,0"/>
                                <TextBlock Text="{Binding FpsStr, StringFormat='FPS: {0}'}"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                FontSize="11"
                                                Margin="0,0,15,0"/>
                                <TextBlock Text="{Binding Codec, StringFormat='Codec: {0}'}"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                FontSize="11"
                                                Margin="0,0,15,0"/>
                                <TextBlock Text="{Binding Bitrate, StringFormat='Bitrate: {0}'}"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                FontSize="11"
                                                Margin="0,0,15,0"/>
                                <TextBlock Text="{Binding Duration, StringFormat='Duration: {0}'}"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                FontSize="11"
                                                Margin="0,0,15,0"/>
                                <TextBlock Text="{Binding AudioInfo, StringFormat='Audio: {0}'}"
                                                Foreground="{StaticResource TextSpecialBrush}"
                                                FontSize="11"/>
                        </WrapPanel>
                </Grid>

                <!-- ROW 2: ТРАНСПОРТ -->
                <Grid Grid.Row="2"
                                Background="{StaticResource SurfaceLightBrush}">
                        <Grid Margin="10,8">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="PreviousBtn"
                                                Click="Previous_Click"
                                                Style="{StaticResource TransportButton}"
                                                Grid.Column="0"
                                                Margin="0,0,8,0"
                                                ToolTip="Previous (Ctrl+Left)">
                                        <TextBlock Text="⏮"
                                                        FontSize="16"/>
                                </Button>
                                <Button x:Name="PlayPauseBtn"
                                                Click="TogglePlayPause_Click"
                                                Style="{StaticResource TransportButton}"
                                                Grid.Column="1"
                                                Margin="0,0,8,0"
                                                ToolTip="Play / Pause (Space)">
                                        <TextBlock x:Name="PlayIcon"
                                                        Text="▶"
                                                        FontSize="20"/>
                                </Button>
                                <Button x:Name="NextBtn"
                                                Click="Next_Click"
                                                Style="{StaticResource TransportButton}"
                                                Grid.Column="2"
                                                Margin="0,0,8,0"
                                                ToolTip="Next (Ctrl+Right)">
                                        <TextBlock Text="⏭"
                                                        FontSize="16"/>
                                </Button>
                                <Button x:Name="StopBtn"
                                                Click="Stop_Click"
                                                Style="{StaticResource TransportButton}"
                                                Grid.Column="3"
                                                Margin="0,0,8,0"
                                                ToolTip="Stop (Ctrl+S)">
                                        <TextBlock Text="■"
                                                        FontSize="18"/>
                                </Button>
                                <Button x:Name="LoadButton"
                                                Click="LoadMultiple_Click"
                                                Style="{StaticResource LoadButtonStyle}"
                                                Grid.Column="4"
                                                Margin="0,0,15,0"
                                                ToolTip="Open files (Ctrl+L / Ctrl+O)">
                                        <TextBlock Text="📂"
                                                        FontSize="18"/>
                                </Button>
                                <TextBlock Grid.Column="5"
                                                Text="⚡"
                                                Foreground="#FFD700"
                                                FontSize="16"
                                                VerticalAlignment="Center"
                                                Margin="0,0,4,0"/>
                                <ComboBox x:Name="SpeedCombo"
                                                Grid.Column="6"
                                                Style="{StaticResource CompactSpeedComboBox}"
                                          SelectedIndex="{Binding SelectedSpeedIndex, Mode=TwoWay}"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left"
                                                ToolTip="Playback speed"/>
                                <StackPanel Orientation="Horizontal"
                                                Grid.Column="8"
                                                VerticalAlignment="Center"
                                                Margin="20,0">
                                        <TextBlock Text="{Binding CurrentTimeStr}"
                                                        Foreground="{StaticResource TextSpecialBrush}"
                                                        FontFamily="{StaticResource MonospaceFont}"
                                                        FontSize="14"
                                                        FontWeight="Bold"/>
                                        <TextBlock Text=" / "
                                                        Foreground="{StaticResource TextSecondaryBrush}"
                                                        FontSize="14"
                                                        Margin="5,0"/>
                                        <TextBlock Text="{Binding TotalTimeStr}"
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        FontFamily="{StaticResource MonospaceFont}"
                                                        FontSize="12"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                                Grid.Column="9"
                                                VerticalAlignment="Center"
                                                Margin="15,0,0,0">
                                        <CheckBox x:Name="VideoCheck"
                                                        Content="🎥 Video"
                                                        IsChecked="True"
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        Margin="0,0,15,0"
                                                        FontSize="12"
                                                        ToolTip="Enable/disable video track"/>
                                        <CheckBox x:Name="AudioCheck"
                                                        Content="🎧 Audio"
                                                        IsChecked="True"
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        Margin="0,0,15,0"
                                                        FontSize="12"
                                                        ToolTip="Enable/disable audio track"/>
                                        <CheckBox x:Name="LoopCheck"
                                                        Content="🔁 Loop"
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        FontSize="12"
                                                        ToolTip="Loop playback"/>
                                </StackPanel>
                        </Grid>
                </Grid>

                <!-- ROW 3: ТАЙМЛАЙН -->
                <Grid Grid.Row="3"
                                Background="#161616">
                        <Grid Margin="10,8">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Timeline"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                FontSize="10"
                                                VerticalAlignment="Center"
                                                Margin="0,0,10,0"/>
                                <controls:TimelineControl x:Name="Timeline"
                                                Grid.Column="1"/>
                                <StackPanel Grid.Column="2"
                                                Orientation="Horizontal"
                                                Margin="10,0,0,0">
                                        <Button x:Name="ZoomInBtn"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Width="30"
                                                        Height="26"
                                                        Margin="0,0,6,0"
                                                        ToolTip="Zoom in timeline">
                                                <TextBlock Text="+"
                                                                FontSize="14"/>
                                        </Button>
                                        <Button x:Name="ZoomOutBtn"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Width="30"
                                                        Height="26"
                                                        ToolTip="Zoom out timeline">
                                                <TextBlock Text="-"
                                                                FontSize="14"/>
                                        </Button>
                                </StackPanel>
                        </Grid>
                </Grid>

                <!-- ROW 4: ПАНЕЛЬ ДЕЙСТВИЙ -->
                <Border Grid.Row="4"
                                Margin="10,4,10,4"
                                CornerRadius="4"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1">
                        <Grid Margin="8,6">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Center">
                                        <StackPanel Orientation="Vertical"
                                                        Margin="10,0">
                                                <TextBlock Text="Playback"
                                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="10"
                                                                Margin="0,0,0,4"
                                                                HorizontalAlignment="Center"/>
                                                <Button Command="{Binding PreviewSegmentCommand}"
                                                        Style="{StaticResource PrimaryButton}"
                                                                Width="90"
                                                        ToolTip="Preview selected segment">
                                                        <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="▶ "
                                                                                FontSize="10"/>
                                                                <TextBlock Text="Preview"
                                                                                FontSize="11"/>
                                                        </StackPanel>
                                                </Button>
                                        </StackPanel>
                                        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                                                        Margin="10,4"/>
                                        <StackPanel Orientation="Vertical"
                                                        Margin="10,0">
                                                <TextBlock Text="Export"
                                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="10"
                                                                Margin="0,0,0,4"
                                                                HorizontalAlignment="Center"/>
                                                <StackPanel Orientation="Horizontal">
                                                        <Button Command="{Binding ExportSelectedCommand}"
                                                                Style="{StaticResource SecondaryButton}"
                                                                        Width="80"
                                                                        Margin="0,0,6,0"
                                                                ToolTip="Export selected segments">
                                                                <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="📤 "
                                                                                        FontSize="10"/>
                                                                        <TextBlock Text="Export Sel"
                                                                                        FontSize="11"/>
                                                                </StackPanel>
                                                        </Button>
                                                        <Button Command="{Binding ExportAllCommand}"
                                                                Style="{StaticResource SecondaryButton}"
                                                                        Width="80"
                                                                ToolTip="Export all segments">
                                                                <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="📦 "
                                                                                        FontSize="10"/>
                                                                        <TextBlock Text="Export All"
                                                                                        FontSize="11"/>
                                                                </StackPanel>
                                                        </Button>
                                                </StackPanel>
                                        </StackPanel>
                                        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                                                        Margin="10,4"/>
                                        <StackPanel Orientation="Vertical"
                                                        Margin="10,0">
                                                <TextBlock Text="Edit"
                                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="10"
                                                                Margin="0,0,0,4"
                                                                HorizontalAlignment="Center"/>
                                                <StackPanel Orientation="Horizontal">
                                                        <Button Command="{Binding UndoMarkerCommand}"
                                                                Style="{StaticResource SecondaryButton}"
                                                                        Width="80"
                                                                        Margin="0,0,6,0"
                                                                ToolTip="Undo last cut (Ctrl+Z)">
                                                                <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="↩️ "
                                                                                        FontSize="10"/>
                                                                        <TextBlock Text="Undo"
                                                                                        FontSize="11"/>
                                                                </StackPanel>
                                                        </Button>
                                                        <Button Command="{Binding ClearCutsCommand}"
                                                                Style="{StaticResource SecondaryButton}"
                                                                        Width="80"
                                                                ToolTip="Clear all cut points">
                                                                <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="🗑️ "
                                                                                        FontSize="10"/>
                                                                        <TextBlock Text="Clear Cuts"
                                                                                        FontSize="11"/>
                                                                </StackPanel>
                                                        </Button>
                                                </StackPanel>
                                        </StackPanel>
                                </StackPanel>
                                <ProgressBar x:Name="ExportProgress"
                                                Grid.Row="1"
                                             Style="{StaticResource CustomProgressBar}"
                                             Margin="0,8,0,0"
                                                Height="18"
                                             Minimum="0"
                                                Maximum="100"
                                                Value="0"/>
                        </Grid>
                </Border>

                <!-- ROW 5: МОНТАЖНЫЙ СТОЛ -->
                <Grid Grid.Row="5"
                                Margin="10,5,10,5"
                                AllowDrop="True"
                                Drop="MontageTable_Drop"
                                DragOver="MontageTable_DragOver">
                        <Border BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                CornerRadius="{StaticResource CardCornerRadius}"
                                        Background="{StaticResource SurfaceBrush}">
                                <Grid>
                                        <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0"
                                                        Background="{StaticResource SurfaceLightBrush}"
                                                        CornerRadius="6,6,0,0"
                                                        Padding="8,6">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🎬 Montage Table"
                                                                        Foreground="{StaticResource TextSpecialBrush}"
                                                                        FontSize="11"
                                                                        FontWeight="Bold"/>
                                                        <Border Background="{StaticResource AccentBrush}"
                                                                        CornerRadius="10"
                                                                        Padding="4,1"
                                                                        Margin="10,0,0,0">
                                                                <TextBlock Text="{Binding MontageItems.Count, StringFormat={}{0} clips}"
                                                                                Foreground="White"
                                                                                FontSize="9"/>
                                                        </Border>
                                                </StackPanel>
                                        </Border>
                                        <ListBox x:Name="MontageList"
                                                        Grid.Row="1"
                                                        Background="{StaticResource SurfaceBrush}"
                                                 ItemsSource="{Binding MontageItems}"
                                                 MinHeight="70"
                                                        MaxHeight="100"
                                                        BorderThickness="0"
                                                 AllowDrop="True"
                                                        Drop="MontageList_Drop"
                                                        DragOver="MontageList_DragOver"
                                                 VirtualizingStackPanel.IsVirtualizing="True"
                                                 VirtualizingStackPanel.VirtualizationMode="Recycling">
                                                <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                                <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding TypeIcon}"
                                                                                        Margin="0,0,5,0"/>
                                                                        <TextBlock Text="{Binding FileName}"
                                                                                        Margin="0,0,5,0"/>
                                                                        <TextBlock Text="("
                                                                                        Foreground="#888"/>
                                                                        <TextBlock Text="{Binding DurationStr}"
                                                                                        Foreground="#888"/>
                                                                        <TextBlock Text=")"
                                                                                        Foreground="#888"/>
                                                                </StackPanel>
                                                        </DataTemplate>
                                                </ListBox.ItemTemplate>
                                        </ListBox>
                                </Grid>
                        </Border>
                </Grid>

                <!-- ROW 6: СТРОКА СОСТОЯНИЯ -->
                <Grid Grid.Row="6"
                                Background="{StaticResource SurfaceLightBrush}">
                        <Grid Margin="8,4">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding StatusText}"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                FontSize="10"/>
                                <StackPanel Grid.Column="2"
                                                Orientation="Horizontal">
                                        <TextBlock Text="⚡ "
                                                        Foreground="#FFD700"
                                                        FontSize="10"/>
                                        <TextBlock x:Name="FrameCountText"
                                                        Text="0 frames"
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        FontSize="10"
                                                        Margin="0,0,10,0"/>
                                        <TextBlock Text="💾 "
                                                        Foreground="#666666"
                                                        FontSize="10"/>
                                        <TextBlock x:Name="MemoryText"
                                                        Text="0 MB"
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        FontSize="10"/>
                                </StackPanel>
                        </Grid>
                </Grid>
        </Grid>
</Window>