<Window x:Class="AI_Video_ToolKit.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrls="clr-namespace:AI_Video_ToolKit.UI.Controls"
        Title="AI Video Toolkit"
        Height="700"
        Width="1200"
        AllowDrop="True"
        Drop="Window_Drop"
        PreviewKeyDown="Window_KeyDown">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <!-- PLAYLIST -->
        <Border Grid.RowSpan="3"
                Grid.Column="0"
                Background="#111">
            <StackPanel>
                <TextBlock Text="Playlist"
                           Foreground="White"
                           Margin="10"/>

                <ListBox x:Name="PlaylistBox"
                         SelectionChanged="PlaylistBox_SelectionChanged"
                         Background="#222"
                         Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- PREVIEW -->
        <Border Grid.Column="1" Grid.Row="0" Background="Black">
            <ctrls:VideoPreviewControl x:Name="Preview"/>
        </Border>

        <!-- TIMELINE -->
        <ctrls:TimelineControl x:Name="Timeline"
                               Grid.Column="1"
                               Grid.Row="1"/>

        <!-- CONTROLS -->
        <StackPanel Grid.Column="1"
                    Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <Button Content="Load" Click="Load_Click" Margin="5"/>

            <Button Content="⏮" Click="Prev_Click" Margin="5"/>

            <Button Content="Play/Pause"
                    Click="TogglePlayPause_Click"
                    Margin="5"/>

            <Button Content="⏹" Click="Stop_Click" Margin="5"/>

            <Button Content="⏭" Click="Next_Click" Margin="5"/>

            <CheckBox x:Name="LoopCheck"
                      Content="Loop"
                      Margin="10,5"/>

            <TextBlock x:Name="FileNameText"
                       Foreground="White"
                       Margin="20,5"/>
        </StackPanel>
    </Grid>
</Window>