<Window x:Class="AI_Video_ToolKit.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AI_Video_ToolKit.UI.Controls"
        Title="AI Video Toolkit"
        Width="1000"
        Height="720"
        Background="#1e1e1e"
        PreviewKeyDown="Window_PreviewKeyDown"
        AllowDrop="True"
        Drop="Window_Drop">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <controls:VideoPreviewControl x:Name="Preview"
                Grid.Row="0"
                Margin="10"/>

        <Grid Grid.Row="1"
                Margin="10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="FileNameText"
                    Foreground="White"
                    FontSize="14"
                    VerticalAlignment="Center"/>

            <TextBlock x:Name="SpeedText"
                    Grid.Column="1"
                    Foreground="Orange"
                    FontSize="14"
                    VerticalAlignment="Center"
                    Margin="20,0,10,0"
                    Text="x1"/>

            <ComboBox x:Name="SpeedCombo"
                      Grid.Column="2"
                      Width="80"
                      Height="26"
                      VerticalAlignment="Center"
                      SelectionChanged="SpeedCombo_SelectionChanged">
                <ComboBoxItem Content="x1"
                        IsSelected="True"/>
                <ComboBoxItem Content="x2"/>
                <ComboBoxItem Content="x4"/>
                <ComboBoxItem Content="x8"/>
                <ComboBoxItem Content="x16"/>
            </ComboBox>
        </Grid>

        <StackPanel Grid.Row="2"
                Orientation="Vertical"
                Margin="10,0,10,5">
            <TextBlock x:Name="ResolutionText"
                    Foreground="#AAAAAA"
                    Margin="0,0,0,2"/>
            <TextBlock x:Name="FpsText"
                    Foreground="#AAAAAA"
                    Margin="0,0,0,2"/>
            <TextBlock x:Name="CodecText"
                    Foreground="#AAAAAA"
                    Margin="0,0,0,2"/>
            <TextBlock x:Name="DurationText"
                    Foreground="#AAAAAA"/>
        </StackPanel>

        <StackPanel Grid.Row="3"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Margin="0,10">
            <Button Width="80"
                    Height="40"
                    Margin="5"
                    Click="TogglePlayPause_Click">
                <TextBlock x:Name="PlayIcon"
                        Text="▶"
                        FontSize="18"
                        Foreground="White"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
            </Button>

            <Button Width="80"
                    Height="40"
                    Margin="5"
                    Click="Stop_Click">
                <TextBlock Text="■"
                        FontSize="18"
                        Foreground="White"/>
            </Button>

            <Button Width="80"
                    Height="40"
                    Margin="5"
                    Click="Load_Click">
                <TextBlock Text="📂"
                        FontSize="18"/>
            </Button>

            <CheckBox x:Name="LoopCheck"
                    Content="Loop"
                    Foreground="White"
                    VerticalAlignment="Center"
                    Margin="10,0"/>
        </StackPanel>

        <controls:TimelineControl x:Name="Timeline"
                Grid.Row="4"
                Margin="10"/>
    </Grid>
</Window>