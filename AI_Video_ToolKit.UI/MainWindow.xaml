<Window x:Class="AI_Video_ToolKit.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Video Toolkit"
        Height="800" Width="1200"
        Background="#202020"

        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <Grid>

        <!-- ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Background="#2D2D30">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputPathBox"
                     Height="30"
                     Margin="5"
                     VerticalContentAlignment="Center"/>

            <Button Grid.Column="1"
                    Content="..."
                    Height="30"
                    Margin="5"
                    Click="BrowseInput_Click"/>

            <TextBox Grid.Column="2"
                     x:Name="OutputPathBox"
                     Height="30"
                     Margin="5"
                     VerticalContentAlignment="Center"/>

            <Button Grid.Column="3"
                    Content="..."
                    Height="30"
                    Margin="5"
                    Click="BrowseOutput_Click"/>

        </Grid>

        <!-- MAIN -->
        <TabControl Grid.Row="1">

            <TabItem Header="FFmpeg">

                <Grid Margin="5">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="260"/>
                        <RowDefinition Height="140"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- VIDEO -->
                    <Grid Grid.Row="0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="5">

                            <ComboBox x:Name="FileSelector"
                                      Height="28"
                                      SelectionChanged="FileSelector_Changed"/>

                            <TextBlock x:Name="MediaInfoText"
                                       Foreground="White"
                                       Margin="5"
                                       TextWrapping="Wrap"/>

                        </StackPanel>

                        <Grid Grid.Column="1">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="45"/>
                            </Grid.RowDefinitions>

                            <MediaElement x:Name="VideoPlayer"
                                          LoadedBehavior="Manual"
                                          Stretch="Uniform"/>

                            <StackPanel Grid.Row="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center">

                                <Button Content="⏮" Width="40" Margin="5" Click="Prev_Click"/>
                                <Button Content="▶" Width="40" Margin="5" Click="Play_Click"/>
                                <Button Content="⏸" Width="40" Margin="5" Click="Pause_Click"/>
                                <Button Content="⏹" Width="40" Margin="5" Click="Stop_Click"/>
                                <Button Content="⏭" Width="40" Margin="5" Click="Next_Click"/>

                            </StackPanel>

                        </Grid>

                    </Grid>

                    <!-- TIMELINE -->
                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto">

                        <StackPanel x:Name="ImageTimeline"
                                    Orientation="Horizontal"/>
                    </ScrollViewer>

                    <!-- ACTIONS -->
                    <Grid Grid.Row="2">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="Extract"
                                Height="35"
                                Margin="10"
                                Click="ExtractFrames_Click"/>

                        <Button Grid.Column="1"
                                Content="Build"
                                Height="35"
                                Margin="10"
                                Click="BuildVideo_Click"/>

                    </Grid>

                </Grid>

            </TabItem>

            <TabItem Header="Real-ESRGAN"/>
            <TabItem Header="RIFE"/>

        </TabControl>

        <!-- STATUS -->
        <StatusBar Grid.Row="2">
            <TextBlock x:Name="StatusText" Text="Ready"/>
        </StatusBar>

    </Grid>
</Window>