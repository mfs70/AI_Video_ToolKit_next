<Window x:Class="AI_Video_ToolKit.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AI_Video_ToolKit.UI.Controls"
        Title="AI Video Toolkit"
        Height="800"
        Width="1200">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <!-- Preview -->
        <local:VideoPreviewControl x:Name="Preview"/>

        <!-- 🔥 КЛЮЧЕВОЙ ФИКС -->
        <local:TimelineControl x:Name="Timeline"
                               Grid.Row="1"/>

        <!-- Controls -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Button Content="Load Video" Click="Load_Click" Width="120"/>
            <Button Content="Stop" Click="Stop_Click" Width="120"/>
        </StackPanel>
    </Grid>
</Window>