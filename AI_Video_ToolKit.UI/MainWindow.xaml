<Window x:Class="AI_Video_ToolKit.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AI_Video_ToolKit.UI.Controls"
        Title="AI Video Toolkit"
        Width="1300"
        Height="780"
        Background="#1e1e1e"
        PreviewKeyDown="Window_PreviewKeyDown"
        AllowDrop="True"
        Drop="Window_Drop">

    <!-- 
        =======================================================
        ОСНОВНОЙ КОНТЕЙНЕР С РАЗБИВКОЙ ПО СТРОКАМ
        Сетка разделена на 6 строк:
        Row 0: Главная рабочая область (видео + панель управления)
        Row 1: Информация о текущем файле и скорость воспроизведения
        Row 2: Метаданные видео (разрешение, FPS, кодек, битрейт, длительность, аудио)
        Row 3: Панель транспорта (Play, Stop, Load) и опции (Видео/Аудио/Loop)
        Row 4: Визуальный таймлайн с маркерами отрезков
        Row 5: Список собранных клипов для монтажа
        =======================================================
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- =========================================== -->
        <!-- ROW 0: ОСНОВНАЯ РАБОЧАЯ ОБЛАСТЬ              -->
        <!-- Содержит две колонки:                        -->
        <!-- Col 0: Видео превью (4 части ширины)         -->
        <!-- Col 1: Правая панель (1.4 части)             -->
        <!-- =========================================== -->
        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="1.4*"/>
            </Grid.ColumnDefinitions>

            <!-- Видео превью (пользовательский элемент управления) -->
            <controls:VideoPreviewControl x:Name="Preview" Grid.Column="0" Margin="0,0,10,0"/>

            <!-- Правая панель инструментов -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>

                <!-- БЛОК ЛОГГЕРА -->
                <Border Grid.Row="0" Background="#121212" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,0,6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Logger" Foreground="#DDD" FontSize="12" Margin="0,0,0,4"/>
                        <ListBox x:Name="LogList" Grid.Row="1" Background="#101010" Foreground="#A5E1A5" BorderThickness="0" FontFamily="Consolas" FontSize="11"/>
                    </Grid>
                </Border>

                <!-- БЛОК СПИСКА СЕГМЕНТОВ -->
                <Border Grid.Row="1" Background="#121212" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,0,6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Segments" Foreground="#DDD" FontSize="12" Margin="0,0,0,4"/>
                        <ListBox x:Name="SegmentList" Grid.Row="1" Background="#101010" Foreground="#E0E0E0" BorderThickness="0" FontFamily="Consolas" FontSize="11" SelectionChanged="SegmentList_SelectionChanged"/>
                    </Grid>
                </Border>

                <!-- БЛОК ДЕЙСТВИЙ (КНОПКИ) -->
                <StackPanel Grid.Row="2" Orientation="Vertical" MinWidth="180">
                    <Button Height="34" Margin="0,0,0,4" Click="PreviewSegment_Click">
                        <TextBlock Text="Preview Segment" FontSize="12"/>
                    </Button>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Width="86" Height="30" Margin="0,0,6,0" Click="ExportSelected_Click">
                            <TextBlock Text="Export Sel" FontSize="11"/>
                        </Button>
                        <Button Width="86" Height="30" Click="Cut_Click">
                            <TextBlock Text="Export All" FontSize="11"/>
                        </Button>
                    </StackPanel>
                    
                    <Button Height="30" Margin="0,0,0,4" Click="MergeSelected_Click">
                        <TextBlock Text="Merge Selected" FontSize="11"/>
                    </Button>
                    
                    <ProgressBar x:Name="ExportProgress" Height="12" Margin="0,0,0,4" Minimum="0" Maximum="100"/>
                    
                    <Button Height="34" Margin="0,0,0,4" Click="UndoMarker_Click">
                        <TextBlock Text="Undo Marker (Ctrl+Z)" FontSize="12"/>
                    </Button>
                    
                    <Button Height="34" Margin="0,0,0,4" Click="ClearCuts_Click">
                        <TextBlock Text="Clear Cuts" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- =========================================== -->
        <!-- ROW 1: ИНФОРМАЦИЯ О ФАЙЛЕ И СКОРОСТЬ         -->
        <!-- =========================================== -->
        <Grid Grid.Row="1" Margin="10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="FileNameText" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
            <ComboBox x:Name="SpeedCombo" Grid.Column="2" Width="48" Height="24" VerticalAlignment="Center" SelectionChanged="SpeedCombo_SelectionChanged">
                <ComboBoxItem Content="x1" IsSelected="True"/>
                <ComboBoxItem Content="x2"/>
                <ComboBoxItem Content="x4"/>
                <ComboBoxItem Content="x8"/>
                <ComboBoxItem Content="x16"/>
            </ComboBox>
        </Grid>

        <!-- =========================================== -->
        <!-- ROW 2: МЕТАДАННЫЕ ВИДЕО                      -->
        <!-- =========================================== -->
        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="10,0,10,5">
            <TextBlock x:Name="ResolutionText" Foreground="#AAAAAA" Margin="0,0,0,2"/>
            <TextBlock x:Name="FpsText" Foreground="#AAAAAA" Margin="0,0,0,2"/>
            <TextBlock x:Name="CodecText" Foreground="#AAAAAA" Margin="0,0,0,2"/>
            <TextBlock x:Name="BitrateText" Foreground="#AAAAAA" Margin="0,0,0,2"/>
            <TextBlock x:Name="DurationText" Foreground="#AAAAAA"/>
            <TextBlock x:Name="AudioInfoText" Foreground="#AAAAAA" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- =========================================== -->
        <!-- ROW 3: ТРАНСПОРТ И ОПЦИИ                    -->
        <!-- =========================================== -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button Width="80" Height="40" Margin="5" Click="TogglePlayPause_Click">
                <TextBlock x:Name="PlayIcon" Text="▶" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
            
            <Button Width="80" Height="40" Margin="5" Click="Stop_Click">
                <TextBlock Text="■" FontSize="18" Foreground="White"/>
            </Button>
            
            <Button Width="80" Height="40" Margin="5" Click="Load_Click">
                <TextBlock Text="📂" FontSize="18"/>
            </Button>
            
            <CheckBox x:Name="VideoCheck" Content="Видео" IsChecked="True" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
            <CheckBox x:Name="AudioCheck" Content="Аудио" IsChecked="True" Foreground="White" VerticalAlignment="Center" Margin="5,0"/>
            <CheckBox x:Name="LoopCheck" Content="Loop" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
        </StackPanel>

        <!-- =========================================== -->
        <!-- ROW 4: ТАЙМЛАЙН С МАРКЕРАМИ                 -->
        <!-- =========================================== -->
        <controls:TimelineControl x:Name="Timeline" Grid.Row="4" Margin="10"/>

        <!-- =========================================== -->
        <!-- ROW 5: СПИСОК МОНТАЖА (MONTAGE LIST)        -->
        <!-- =========================================== -->
        <ListBox x:Name="MontageList" Grid.Row="5" Margin="10,0,10,10" Height="80" Background="#151515" Foreground="#EFEFEF"/>
    </Grid>
</Window>