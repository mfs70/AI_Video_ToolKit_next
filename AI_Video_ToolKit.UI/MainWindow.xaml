<Window x:Class="AI_Video_ToolKit.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Video Toolkit"
        Height="700"
        Width="1200"
        Background="#202020">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TOP -->
        <Grid Grid.Row="0"
              Grid.ColumnSpan="2"
              Background="#2D2D30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputPathBox"
                     Margin="10"
                     VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Content="Browse"
                    Click="BrowseInput_Click"/>

            <TextBox Grid.Column="2"
                     x:Name="OutputPathBox"
                     Margin="10"
                     VerticalAlignment="Center"/>
            <Button Grid.Column="3"
                    Content="Browse"
                    Click="BrowseOutput_Click"/>
        </Grid>

        <!-- LEFT -->
        <StackPanel Grid.Row="1"
                    Grid.Column="0"
                    Background="#252526">
            <Button Content="Probe"
                    Height="50"
                    Margin="10"
                    Click="Probe_Click"/>
            <Button Content="Preview"
                    Height="50"
                    Margin="10"
                    Click="Preview_Click"/>
            <Button Content="Encode"
                    Height="50"
                    Margin="10"
                    Click="Encode_Click"/>
        </StackPanel>

        <!-- RIGHT -->
        <Grid Grid.Row="1"
              Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="250"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBox x:Name="MediaInfoBox"
                     Grid.Row="0"
                     Margin="10"
                     Background="#111"
                     Foreground="White"
                     FontFamily="Consolas"
                     IsReadOnly="True"
                     TextWrapping="Wrap"/>

            <TextBox x:Name="LogBox"
                     Grid.Row="1"
                     Margin="10"
                     Background="#000"
                     Foreground="#00FF00"
                     FontFamily="Consolas"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <!-- STATUS -->
        <TextBlock Grid.Row="2"
                   Grid.ColumnSpan="2"
                   x:Name="StatusText"
                   Text="Ready"
                   Margin="10"
                   Foreground="White"/>
    </Grid>
</Window>