<Window x:Class="AI_Video_ToolKit.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Toolkit"
        Height="750"
                Width="1000"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

        <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition/>
                        <RowDefinition Height="140"/>
                </Grid.RowDefinitions>

                <!-- TOP -->
                <StackPanel Orientation="Horizontal"
                                Grid.Row="0">
                        <Button Content="Open Files"
                                        Width="120"
                                        Margin="5"
                                        Click="OpenFiles_Click"/>
                        <TextBlock x:Name="CurrentFileText"
                                        VerticalAlignment="Center"
                                        Margin="10,0"/>
                </StackPanel>

                <!-- PLAYER / IMAGE -->
                <Grid Grid.Row="1">

                        <MediaElement x:Name="VideoPlayer"
                                      LoadedBehavior="Manual"
                                      Stretch="Uniform"/>

                        <Image x:Name="ImageViewer"
                               Stretch="Uniform"
                               Visibility="Collapsed"/>

                        <Canvas x:Name="CropCanvas"
                                        Background="Transparent"/>
                </Grid>

                <!-- CONTROLS -->
                <StackPanel Grid.Row="2">

                        <StackPanel Orientation="Horizontal">
                                <Button Content="⏮"
                                                Width="50"
                                                Click="Prev_Click"/>
                                <Button Content="▶"
                                                Width="50"
                                                Click="Play_Click"/>
                                <Button Content="⏸"
                                                Width="50"
                                                Click="Pause_Click"/>
                                <Button Content="⏹"
                                                Width="50"
                                                Click="Stop_Click"/>
                                <Button Content="⏭"
                                                Width="50"
                                                Click="Next_Click"/>

                                <Button Content="Trim"
                                                Margin="10,0"
                                                Click="Trim_Click"/>
                                <Button Content="Split"
                                                Click="Split_Click"/>
                                <Button Content="Crop"
                                                Click="Crop_Click"/>
                                <Button Content="Probe"
                                                Click="Probe_Click"/>
                        </StackPanel>

                        <TextBox x:Name="LogBox"
                                 Margin="5"
                                 Height="80"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>
                </StackPanel>

        </Grid>
</Window>