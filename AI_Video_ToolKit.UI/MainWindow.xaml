<Window x:Class="AI_Video_ToolKit.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AI_Video_ToolKit.UI.Controls"
        Title="AI Video Toolkit"
        Width="1000"
        Height="720"
        Background="#1e1e1e"
        PreviewKeyDown="Window_PreviewKeyDown"
        AllowDrop="True"
        Drop="Window_Drop">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- VIDEO -->
        <controls:VideoPreviewControl x:Name="Preview"
                                      Grid.Row="0"
                                      Margin="10"/>

        <!-- FILE + SPEED -->
        <Grid Grid.Row="1" Margin="10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- имя файла -->
            <TextBlock x:Name="FileNameText"
                       Foreground="White"
                       FontSize="14"
                       VerticalAlignment="Center"/>

            <!-- скорость -->
            <TextBlock x:Name="SpeedText"
                       Grid.Column="1"
                       Foreground="Orange"
                       FontSize="14"
                       VerticalAlignment="Center"
                       Margin="20,0,0,0"
                       Text="x1"/>
        </Grid>

        <!-- CONTROLS -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10">

            <!-- PLAY / PAUSE -->
            <Button x:Name="PlayButton"
                    Width="80"
                    Height="40"
                    Margin="5"
                    Click="TogglePlayPause_Click">
                <TextBlock x:Name="PlayIcon"
                           Text="▶"
                           FontSize="18"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Button>

            <!-- STOP -->
            <Button Width="80"
                    Height="40"
                    Margin="5"
                    Click="Stop_Click">
                <TextBlock Text="■"
                           FontSize="18"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Button>

            <!-- LOAD -->
            <Button Width="80"
                    Height="40"
                    Margin="5"
                    Click="Load_Click">
                <TextBlock Text="📂"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Button>

            <!-- LOOP -->
            <CheckBox x:Name="LoopCheck"
                      Content="Loop"
                      Foreground="White"
                      VerticalAlignment="Center"
                      Margin="10,0"/>
        </StackPanel>

        <!-- TIMELINE -->
        <controls:TimelineControl x:Name="Timeline"
                                 Grid.Row="3"
                                 Margin="10"/>
    </Grid>
</Window>