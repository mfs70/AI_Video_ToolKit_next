<Window x:Class="AI_Video_ToolKit.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AI_Video_ToolKit.UI.Controls"
        Title="AI Video Toolkit"
        Width="1000" Height="720"
        KeyDown="Window_KeyDown"
        AllowDrop="True"
        Drop="Window_Drop">

    <Grid Background="#1e1e1e">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>  <!-- имя файла -->
            <RowDefinition Height="Auto"/>  <!-- кнопки -->
            <RowDefinition Height="Auto"/>  <!-- таймлайн -->
        </Grid.RowDefinitions>

        <!-- VIDEO -->
        <controls:VideoPreviewControl x:Name="Preview"
                                      Grid.Row="0"
                                      Margin="10"/>

        <!-- FILE NAME -->
        <TextBlock x:Name="FileNameText"
                   Grid.Row="1"
                   Foreground="White"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   Margin="0,5"/>

        <!-- CONTROLS -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10">

            <Button x:Name="PlayButton"
                    Content="Play"
                    Width="100"
                    Height="40"
                    Margin="5"
                    Click="TogglePlayPause_Click"/>

            <Button Content="Stop"
                    Width="100"
                    Height="40"
                    Margin="5"
                    Click="Stop_Click"/>

            <Button Content="Load"
                    Width="100"
                    Height="40"
                    Margin="5"
                    Click="Load_Click"/>

            <CheckBox x:Name="LoopCheck"
                      Content="Loop"
                      Foreground="White"
                      VerticalAlignment="Center"
                      Margin="10,0"/>
        </StackPanel>

        <!-- TIMELINE -->
        <controls:TimelineControl x:Name="Timeline"
                                 Grid.Row="3"
                                 Margin="10"/>
    </Grid>
</Window>