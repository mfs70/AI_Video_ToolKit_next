<Window x:Class="AI_Video_ToolKit.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AI_Video_ToolKit.UI.Controls"
        Title="AI Video Toolkit - Professional Video Editor"
        Width="1400"
        Height="850"
        MinWidth="1000"
        MinHeight="600"
        Background="#1e1e1e"
        PreviewKeyDown="Window_PreviewKeyDown"
        AllowDrop="True"
        Drop="Window_Drop"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal">

    <Window.Resources>

        <!-- Стиль для синих кнопок -->
        <Style x:Key="PrimaryButton"
                TargetType="Button">
            <Setter Property="Background"
                    Value="#3a6ea5"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Padding"
                    Value="12,8"/>
            <Setter Property="FontSize"
                    Value="12"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter Property="Background"
                                        Value="#2c5a8c"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для серых кнопок -->
        <Style x:Key="SecondaryButton"
                TargetType="Button">
            <Setter Property="Background"
                    Value="#2c2c2c"/>
            <Setter Property="Foreground"
                    Value="#e0e0e0"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="BorderBrush"
                    Value="#555"/>
            <Setter Property="Padding"
                    Value="10,6"/>
            <Setter Property="FontSize"
                    Value="11"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter Property="Background"
                                        Value="#3c3c3c"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для круглых кнопок транспорта -->
        <Style x:Key="TransportButton"
                TargetType="Button">
            <Setter Property="Width"
                    Value="42"/>
            <Setter Property="Height"
                    Value="42"/>
            <Setter Property="Background"
                    Value="#2c2c2c"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontSize"
                    Value="18"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="21"
                                Padding="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter Property="Background"
                                        Value="#3a6ea5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для кнопки загрузки в строке транспорта -->
        <Style x:Key="LoadTransportButton"
                TargetType="Button">
            <Setter Property="Width"
                    Value="42"/>
            <Setter Property="Height"
                    Value="42"/>
            <Setter Property="Background"
                    Value="#2c2c2c"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontSize"
                    Value="18"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="21"
                                Padding="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter Property="Background"
                                        Value="#4c9aff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Компактный стиль для ComboBox - только цифры -->
        <Style x:Key="CompactSpeedComboBox"
                TargetType="ComboBox">
            <Setter Property="Width"
                    Value="55"/>
            <Setter Property="Height"
                    Value="30"/>
            <Setter Property="Background"
                    Value="#FFFFFF"/>
            <Setter Property="Foreground"
                    Value="#000000"/>
            <Setter Property="BorderBrush"
                    Value="#3a6ea5"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="FontSize"
                    Value="12"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Center"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
        </Style>

        <!-- Стиль для элементов выпадающего списка -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background"
                    Value="#2c2c2c"/>
            <Setter Property="Foreground"
                    Value="#FFFFFF"/>
            <Setter Property="Height"
                    Value="28"/>
            <Setter Property="Padding"
                    Value="8,4"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted"
                        Value="True">
                    <Setter Property="Background"
                            Value="#3a6ea5"/>
                    <Setter Property="Foreground"
                            Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для ListBox -->
        <Style TargetType="ListBox">
            <Setter Property="Background"
                    Value="#0c0c0c"/>
            <Setter Property="BorderBrush"
                    Value="#3a3a3a"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="FontFamily"
                    Value="Consolas"/>
            <Setter Property="FontSize"
                    Value="11"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding"
                    Value="8,6"/>
            <Setter Property="Foreground"
                    Value="#e0e0e0"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected"
                        Value="True">
                    <Setter Property="Background"
                            Value="#3a6ea5"/>
                    <Setter Property="Foreground"
                            Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver"
                        Value="True">
                    <Setter Property="Background"
                            Value="#2a2a2a"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для ProgressBar -->
        <Style TargetType="ProgressBar">
            <Setter Property="Height"
                    Value="6"/>
            <Setter Property="Background"
                    Value="#2b2b2b"/>
            <Setter Property="Foreground"
                    Value="#4c9aff"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
        </Style>

        <!-- Стиль для GroupBox -->
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush"
                    Value="#444"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Background"
                    Value="#121212"/>
            <Setter Property="Foreground"
                    Value="#ddd"/>
            <Setter Property="FontSize"
                    Value="12"/>
            <Setter Property="Margin"
                    Value="0,0,0,8"/>
            <Setter Property="Padding"
                    Value="6"/>
        </Style>
    </Window.Resources>

    <!-- ==================== ОСНОВНОЙ GRID ==================== -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Toolbar (скрыт) -->
            <RowDefinition Height="*"/>
            <!-- Main content -->
            <RowDefinition Height="Auto"/>
            <!-- Video info -->
            <RowDefinition Height="Auto"/>
            <!-- Transport -->
            <RowDefinition Height="Auto"/>
            <!-- Timeline -->
            <RowDefinition Height="Auto"/>
            <!-- Montage list -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ==================== ROW 0: TOOLBAR (скрыт) ==================== -->
        <Grid Grid.Row="0"
                Background="#252526"
                Height="0"
                Visibility="Collapsed"/>

        <!-- ==================== ROW 1: MAIN AREA ==================== -->
        <Grid Grid.Row="1"
                Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <!-- Video Preview -->
            <Border Grid.Column="0"
                    Background="#000000"
                    BorderBrush="#3a3a3a"
                    BorderThickness="1"
                    CornerRadius="8">
                <controls:VideoPreviewControl x:Name="Preview"/>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                    Width="4"
                    HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                    Background="#3a3a3a"/>

            <!-- Right Panel -->
            <StackPanel Grid.Column="2"
                    Orientation="Vertical">

                <!-- Logger -->
                <GroupBox Header="📋 Logger (Console Output)"
                        Height="180">
                    <ListBox x:Name="LogList"
                            Background="#0c0c0c"
                            Foreground="#a5e1a5"
                            FontSize="10"/>
                </GroupBox>

                <!-- Segments List -->
                <GroupBox Header="✂️ Segments (Cut Points)"
                        Height="160">
                    <ListBox x:Name="SegmentList"
                            Background="#0c0c0c"
                            Foreground="#e0e0e0"
                             SelectionChanged="SegmentList_SelectionChanged"/>
                </GroupBox>

                <!-- Actions -->
                <GroupBox Header="🎬 Actions">
                    <StackPanel>
                        <WrapPanel Margin="0,0,0,6">
                            <Button x:Name="PreviewSegmentBtn"
                                    Click="PreviewSegment_Click"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,6,0"
                                    Width="110">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▶ "
                                            FontSize="10"/>
                                    <TextBlock Text="Preview"
                                            FontSize="11"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="ExportSelectedBtn"
                                    Click="ExportSelected_Click"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,6,0"
                                    Width="90">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📤 "
                                            FontSize="10"/>
                                    <TextBlock Text="Export Sel"
                                            FontSize="11"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="ExportAllBtn"
                                    Click="Cut_Click"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,6,0"
                                    Width="90">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📦 "
                                            FontSize="10"/>
                                    <TextBlock Text="Export All"
                                            FontSize="11"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,6">
                            <Button x:Name="MergeSelectedBtn"
                                    Click="MergeSelected_Click"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,6,0"
                                    Width="105">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔗 "
                                            FontSize="10"/>
                                    <TextBlock Text="Merge Sel"
                                            FontSize="11"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="UndoMarkerBtn"
                                    Click="UndoMarker_Click"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,6,0"
                                    Width="125">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="↩️ "
                                            FontSize="10"/>
                                    <TextBlock Text="Undo (Ctrl+Z)"
                                            FontSize="11"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="ClearCutsBtn"
                                    Click="ClearCuts_Click"
                                    Style="{StaticResource SecondaryButton}"
                                    Width="105">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🗑️ "
                                            FontSize="10"/>
                                    <TextBlock Text="Clear Cuts"
                                            FontSize="11"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>

                        <ProgressBar x:Name="ExportProgress"
                                Margin="0,6,0,0"
                                Height="4"
                                     Minimum="0"
                                Maximum="100"
                                Value="0"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </Grid>

        <!-- ==================== ROW 2: VIDEO INFO ==================== -->
        <Grid Grid.Row="2"
                Background="#252526">
            <WrapPanel Margin="10,6"
                    HorizontalAlignment="Left">
                <TextBlock x:Name="FileNameText"
                        Foreground="#ffaa66"
                        FontSize="12"
                           FontWeight="Bold"
                        Margin="0,0,20,0"/>
                <TextBlock x:Name="ResolutionText"
                        Foreground="#CCCCCC"
                        FontSize="11"
                        Margin="0,0,15,0"/>
                <TextBlock x:Name="FpsText"
                        Foreground="#CCCCCC"
                        FontSize="11"
                        Margin="0,0,15,0"/>
                <TextBlock x:Name="CodecText"
                        Foreground="#CCCCCC"
                        FontSize="11"
                        Margin="0,0,15,0"/>
                <TextBlock x:Name="BitrateText"
                        Foreground="#CCCCCC"
                        FontSize="11"
                        Margin="0,0,15,0"/>
                <TextBlock x:Name="DurationText"
                        Foreground="#CCCCCC"
                        FontSize="11"
                        Margin="0,0,15,0"/>
                <TextBlock x:Name="AudioInfoText"
                        Foreground="#4c9aff"
                        FontSize="11"/>
            </WrapPanel>
        </Grid>

        <!-- ==================== ROW 3: TRANSPORT ==================== -->
        <!-- Все кнопки в одну линию: Play, Stop, Load, Speed, Time, Options -->
        <Grid Grid.Row="3"
                Background="#1a1a1a">
            <Grid Margin="10,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Кнопка Play/Pause -->
                <Button x:Name="PlayPauseBtn"
                        Click="TogglePlayPause_Click"
                        Style="{StaticResource TransportButton}"
                        Grid.Column="0"
                        Margin="0,0,8,0">
                    <TextBlock x:Name="PlayIcon"
                            Text="▶"
                            FontSize="20"/>
                </Button>

                <!-- Кнопка Stop -->
                <Button x:Name="StopBtn"
                        Click="Stop_Click"
                        Style="{StaticResource TransportButton}"
                        Grid.Column="1"
                        Margin="0,0,8,0">
                    <TextBlock Text="■"
                            FontSize="18"/>
                </Button>

                <!-- Кнопка Load (Open Video) -->
                <Button x:Name="LoadButton"
                        Click="Load_Click"
                        Style="{StaticResource LoadTransportButton}"
                        Grid.Column="2"
                        Margin="0,0,15,0">
                    <TextBlock Text="📂"
                            FontSize="18"/>
                </Button>

                <!-- Жёлтая молния перед комбобоксом -->
                <TextBlock Grid.Column="3"
                        Text="⚡"
                        Foreground="#FFD700"
                        FontSize="16"
                           VerticalAlignment="Center"
                        Margin="0,0,4,0"/>

                <!-- Компактный ComboBox скорости - только цифры, чёрный текст на белом фоне -->
                <ComboBox x:Name="SpeedCombo"
                        Grid.Column="4"
                        Style="{StaticResource CompactSpeedComboBox}"
                          SelectionChanged="SpeedCombo_SelectionChanged"
                          VerticalAlignment="Center"
                        HorizontalAlignment="Left">
                    <ComboBoxItem Content="1x"
                            IsSelected="True"/>
                    <ComboBoxItem Content="2x"/>
                    <ComboBoxItem Content="4x"/>
                    <ComboBoxItem Content="8x"/>
                    <ComboBoxItem Content="16x"/>
                </ComboBox>

                <!-- Отображение времени -->
                <StackPanel Orientation="Horizontal"
                        Grid.Column="5"
                        VerticalAlignment="Center"
                        Margin="20,0">
                    <TextBlock x:Name="CurrentTimeText"
                            Text="00:00:00"
                            Foreground="#4c9aff"
                               FontFamily="Consolas"
                            FontSize="14"
                            FontWeight="Bold"/>
                    <TextBlock Text=" / "
                            Foreground="#888"
                            FontSize="14"
                            Margin="5,0"/>
                    <TextBlock x:Name="TotalTimeText"
                            Text="00:00:00"
                            Foreground="#CCCCCC"
                               FontFamily="Consolas"
                            FontSize="12"/>
                </StackPanel>

                <!-- Опции воспроизведения -->
                <StackPanel Orientation="Horizontal"
                        Grid.Column="6"
                        VerticalAlignment="Center"
                        Margin="15,0,0,0">
                    <CheckBox x:Name="VideoCheck"
                            Content="🎥 Video"
                            IsChecked="True"
                              Foreground="#CCCCCC"
                            Margin="0,0,15,0"
                            FontSize="12"/>
                    <CheckBox x:Name="AudioCheck"
                            Content="🎧 Audio"
                            IsChecked="True"
                              Foreground="#CCCCCC"
                            Margin="0,0,15,0"
                            FontSize="12"/>
                    <CheckBox x:Name="LoopCheck"
                            Content="🔁 Loop"
                              Foreground="#CCCCCC"
                            FontSize="12"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ==================== ROW 4: TIMELINE ==================== -->
        <Grid Grid.Row="4"
                Background="#161616">
            <Grid Margin="10,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Timeline"
                        Foreground="#888"
                        FontSize="10"
                           VerticalAlignment="Center"
                        Margin="0,0,10,0"/>

                <controls:TimelineControl x:Name="Timeline"
                        Grid.Column="1"/>

                <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Margin="10,0,0,0">
                    <Button x:Name="ZoomInBtn"
                            Style="{StaticResource SecondaryButton}"
                            Width="30"
                            Height="26"
                            Margin="0,0,6,0">
                        <TextBlock Text="+"
                                FontSize="14"/>
                    </Button>
                    <Button x:Name="ZoomOutBtn"
                            Style="{StaticResource SecondaryButton}"
                            Width="30"
                            Height="26">
                        <TextBlock Text="-"
                                FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ==================== ROW 5: MONTAGE LIST ==================== -->
        <Grid Grid.Row="5"
                Margin="10,5,10,5">
            <Border BorderBrush="#3a3a3a"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="#121212">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            Background="#1a1a1a"
                            CornerRadius="6,6,0,0"
                            Padding="8,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎬 Montage List"
                                    Foreground="#4c9aff"
                                    FontSize="11"
                                    FontWeight="Bold"/>
                            <TextBlock Text=" (Export Queue)"
                                    Foreground="#888"
                                    FontSize="10"
                                    Margin="5,0,0,0"/>
                            <Border Background="#3a6ea5"
                                    CornerRadius="10"
                                    Padding="4,1"
                                    Margin="10,0,0,0">
                                <TextBlock x:Name="MontageCount"
                                        Text="0 clips"
                                        Foreground="White"
                                        FontSize="9"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- List -->
                    <ListBox x:Name="MontageList"
                            Grid.Row="1"
                            Background="#121212"
                             MinHeight="70"
                            MaxHeight="100"
                            BorderThickness="0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ==================== ROW 6: STATUS BAR ==================== -->
        <Grid Grid.Row="6"
                Background="#1a1a1a">
            <Grid Margin="8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText"
                        Text="✅ Ready"
                        Foreground="#888"
                        FontSize="10"/>

                <StackPanel Grid.Column="2"
                        Orientation="Horizontal">
                    <TextBlock Text="⚡ "
                            Foreground="#FFD700"
                            FontSize="10"/>
                    <TextBlock x:Name="FrameCountText"
                            Text="0 frames"
                            Foreground="#CCCCCC"
                            FontSize="10"
                            Margin="0,0,10,0"/>
                    <TextBlock Text="💾 "
                            Foreground="#666"
                            FontSize="10"/>
                    <TextBlock x:Name="MemoryText"
                            Text="0 MB"
                            Foreground="#CCCCCC"
                            FontSize="10"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>